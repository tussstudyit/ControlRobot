<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FFFF203D" />
            <stroke
                android:width="1dp"
                android:color="#FFFFC4CD" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#FF8F1E31"
                android:startColor="#FFFF4D66" />
            <stroke
                android:width="1dp"
                android:color="#FFFF9CAB" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
