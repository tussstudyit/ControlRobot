<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#FF0E7D9E"
                android:startColor="#FF26D6FF" />
            <stroke
                android:width="1dp"
                android:color="#FFD8F7FF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#FF142B3A"
                android:startColor="#FF1B4254" />
            <stroke
                android:width="1dp"
                android:color="@color/cyan" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
