<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="24dp"
        android:paddingRight="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/panel_surface_alt"
                android:contentDescription="@null"
                android:padding="9dp"
                android:src="@drawable/ic_bluetooth" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0"
                    android:text="ESP32 PILOT"
                    android:textColor="@color/text_main"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0"
                    android:text="Bluetooth command deck"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_idle"
                android:letterSpacing="0"
                android:text="IDLE"
                android:textColor="@color/amber"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0"
                android:text="Connection"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/deviceSpinner"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/panel_surface_alt"
                    android:popupBackground="@color/panel" />

                <ImageButton
                    android:id="@+id/refreshButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/btn_secondary"
                    android:contentDescription="Refresh"
                    android:padding="14dp"
                    android:src="@drawable/ic_refresh" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/connectButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/btn_primary"
                    android:letterSpacing="0"
                    android:text="CONNECT"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/disconnectButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_secondary"
                    android:letterSpacing="0"
                    android:text="DISCONNECT"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:background="@drawable/metric_box"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0"
                    android:text="DEVICE"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/deviceMetric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:letterSpacing="0"
                    android:maxLines="1"
                    android:text="ESP32_ROBOT"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@drawable/metric_box"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0"
                    android:text="LINK"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/linkMetric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:letterSpacing="0"
                    android:maxLines="1"
                    android:text="Standby"
                    android:textColor="@color/amber"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@drawable/metric_box"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0"
                    android:text="LAST CMD"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lastCommandMetric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0"
                    android:maxLines="1"
                    android:text="S"
                    android:textColor="@color/cyan"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0"
                android:text="Drive Control"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                android:rowCount="3"
                android:useDefaultMargins="false">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp" />

                <Button
                    android:id="@+id/forwardButton"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:background="@drawable/btn_drive"
                    android:drawableTop="@drawable/ic_arrow_up"
                    android:gravity="center"
                    android:letterSpacing="0"
                    android:paddingTop="14dp"
                    android:text="FORWARD"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp" />

                <Button
                    android:id="@+id/leftButton"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:background="@drawable/btn_drive"
                    android:drawableTop="@drawable/ic_arrow_left"
                    android:gravity="center"
                    android:letterSpacing="0"
                    android:paddingTop="14dp"
                    android:text="LEFT"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/stopButton"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:background="@drawable/btn_stop"
                    android:drawableTop="@drawable/ic_stop"
                    android:gravity="center"
                    android:letterSpacing="0"
                    android:paddingTop="15dp"
                    android:text="STOP"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/rightButton"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:background="@drawable/btn_drive"
                    android:drawableTop="@drawable/ic_arrow_right"
                    android:gravity="center"
                    android:letterSpacing="0"
                    android:paddingTop="14dp"
                    android:text="RIGHT"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp" />

                <Button
                    android:id="@+id/backwardButton"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:background="@drawable/btn_drive"
                    android:drawableTop="@drawable/ic_arrow_down"
                    android:gravity="center"
                    android:letterSpacing="0"
                    android:paddingTop="14dp"
                    android:text="BACK"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp" />
            </GridLayout>

            <Button
                android:id="@+id/emergencyStopButton"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_stop"
                android:drawableLeft="@drawable/ic_stop"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:letterSpacing="0"
                android:text="EMERGENCY STOP"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0"
                android:text="Command Stream"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/logText"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_surface_alt"
                android:gravity="bottom"
                android:letterSpacing="0"
                android:padding="12dp"
                android:text="Waiting for paired Bluetooth device..."
                android:textColor="@color/text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
